DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=verify-full&connect_timeout=10&pool_timeout=10"
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"
# Dev: usa host directo (sin -pooler) para evitar wake-up del pooler.
# Prod: Neon console entrega el connection string con -pooler, usalo ahi.
